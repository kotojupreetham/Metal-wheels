# Professional .gitignore for Metal Wheels static website

# IDE / Editor configurations
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Build and distribution directories
build/
dist/
out/

# Dependencies
node_modules/
jspm_packages/
bower_components/

# Mobile / Android / Flutter (if applicable)
.gradle/
*.keystore
*.jks
local.properties
firebase_options.dart

# Logs and databases
*.log
*.sqlite
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment and sensitive keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
credentials.json
client_secret.json

# Temporary / OS / Cache files
.DS_Store
Thumbs.db
*.tmp
*.cache
*.bak
*.swp
*~
.sass-cache/

# Generated files
generated/
